{
  "name": "chophub",
  "version": "0.1.0",
  "private": true,
  "description": "Nigerian food marketplace — vendors list catfish, frozen chicken, cooked African foods; customers order via Monnify.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "api": "npm run dev --workspace apps/api",
    "web": "npm run dev --workspace apps/web"
  },
  "engines": {
    "node": ">=18"
  }
}
