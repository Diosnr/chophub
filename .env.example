# ============================================
# ChopHub API — apps/api/.env
# ============================================
# Copy this file to .env and fill in real values

# MongoDB Atlas (free M0 cluster)
MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/chophub?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Monnify (https://monnify.com)
MONNIFY_API_KEY=your-monnify-api-key
MONNIFY_SECRET_KEY=your-monnify-secret-key
MONNIFY_CONTRACT_CODE=your-contract-code
MONNIFY_WEBHOOK_SECRET=your-webhook-secret

# Server
PORT=4000
NODE_ENV=development

# ============================================
# ChopHub Web — apps/web/.env
# ============================================
VITE_API_URL=http://localhost:4000
VITE_MONNIFY_PUBLIC_KEY=your-monnify-public-key
